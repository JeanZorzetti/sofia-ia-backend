# Sofia IA - Production Environment Variables

# === CORE APPLICATION ===
NODE_ENV=production
PORT=8000
APP_NAME=Sofia IA
APP_VERSION=1.0.0

# === DATABASE (SUPABASE) ===
# Você precisa preencher estes valores do seu Supabase:
DATABASE_URL=postgresql://username:password@host:port/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# === AUTHENTICATION ===
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# === CLAUDE AI ===
ANTHROPIC_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4000

# === EVOLUTION API (WHATSAPP) ===
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=sofia-ia-main

# === N8N INTEGRATION ===
N8N_URL=https://n8n.roilabs.com.br
N8N_API_KEY=your-n8n-api-key

# === REDIS (CACHE) ===
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# === SECURITY ===
CORS_ORIGINS=https://sofia-ia-dashboard-jtwqjaely-jean-zorzettis-projects.vercel.app,http://localhost:8080
API_RATE_LIMIT=100
WEBHOOK_SECRET=your-webhook-secret

# === LOGGING ===
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# === EMAIL (OPCIONAL) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# === MONITORING (OPCIONAL) ===
SENTRY_DSN=your-sentry-dsn
ANALYTICS_ID=your-analytics-id
